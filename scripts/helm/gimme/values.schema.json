{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Gimme Helm Chart Values",
  "type": "object",
  "properties": {
    "replicaCount": {
      "type": "integer",
      "minimum": 1
    },
    "image": {
      "type": "object",
      "properties": {
        "repository": { "type": "string" },
        "tag": { "type": "string" },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      },
      "additionalProperties": false
    },
    "imagePullSecrets": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" }
        }
      }
    },
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string" },
        "annotations": { "type": "object" }
      },
      "additionalProperties": false
    },
    "podAnnotations": { "type": "object" },
    "podLabels": { "type": "object" },
    "podSecurityContext": { "type": "object" },
    "securityContext": { "type": "object" },
    "resources": {
      "type": "object",
      "properties": {
        "requests": { "type": "object" },
        "limits": { "type": "object" }
      },
      "additionalProperties": false
    },
    "config": {
      "type": "object",
      "properties": {
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "metrics": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "credentials": {
      "type": "object",
      "properties": {
        "secret": { "type": "string" },
        "admin": {
          "type": "object",
          "properties": {
            "user": { "type": "string" },
            "password": { "type": "string" }
          },
          "additionalProperties": false
        },
        "s3": {
          "type": "object",
          "properties": {
            "key": { "type": "string" },
            "secret": { "type": "string" }
          },
          "additionalProperties": false
        },
        "oidcClientSecret": { "type": "string" }
      },
      "additionalProperties": false
    },
    "s3": {
      "type": "object",
      "properties": {
        "url": { "type": "string" },
        "bucketName": { "type": "string" },
        "location": { "type": "string" },
        "ssl": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "cache": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "type": {
          "type": "string",
          "enum": ["redis"]
        },
        "ttl": { "type": "integer" },
        "redisUrl": { "type": "string" }
      },
      "additionalProperties": false
    },
    "auth": {
      "type": "object",
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["basic", "oidc"]
        },
        "oidc": {
          "type": "object",
          "properties": {
            "issuer": { "type": "string" },
            "clientId": { "type": "string" },
            "redirectUrl": { "type": "string" },
            "secureCookies": { "type": "boolean" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "tokenStore": {
      "type": "object",
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["file", "redis", "postgres"]
        },
        "pgUrl": {
          "type": "string"
        }
      },
      "required": ["mode"],
      "additionalProperties": false
    },
    "service": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["ClusterIP", "NodePort", "LoadBalancer"]
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        }
      },
      "additionalProperties": false
    },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "className": { "type": "string" },
        "host": { "type": "string" },
        "annotations": { "type": "object" },
        "tls": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "secretName": { "type": "string" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "hpa": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "minReplicas": {
          "type": "integer",
          "minimum": 1
        },
        "maxReplicas": {
          "type": "integer",
          "minimum": 1
        },
        "targetCPUUtilizationPercentage": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        }
      },
      "additionalProperties": false
    },
    "nodeSelector": { "type": "object" },
    "tolerations": {
      "type": "array",
      "items": { "type": "object" }
    },
    "affinity": { "type": "object" }
  },
  "additionalProperties": false
}
